declare 
    v_deptno emp.deptno%type;
      v_dname dept.dname%type;
      v_loc dept.loc%type;
 
begin 

select max (hiredate)
into v_max_hiredate
from emp;

select deptno
into v_deptno
from emp
where hirdate = v_max_hiredate;

select dname, loc
into v_dname, v_loc
from dept 
where deptno = v_deptno;

dbms_output.putline('Nome do departamento:' ||v_dname||' Cidade:'||v_loc);

end;
