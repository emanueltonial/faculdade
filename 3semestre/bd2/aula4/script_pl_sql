/*set serverout on*/
create or replace procedure p_menor_sal_cidade (p_city dept.loc%type) as
     /* Vars que guardo o valor do meus selects */
    v_deptno dept.deptno%type;
    v_min_sal emp.sal%type;
    v_emp_name emp.ename%type;
    v_sal emp.sal%type;
begin 
    /* Selecionar departamento de uma determinada cidade */
    select deptno 
    into v_deptno
    from dept
    where loc = p_city;

    /* O menor salário */
    select min(sal)
    into v_min_sal
    from emp
    where 
    emp.deptno = v_deptno;

    /* Selecionar o funcionario com o menor salário */
    select ename, sal
    into v_emp_name, v_sal
    from emp 
    where 
    sal = v_min_sal;

        dbms_output.put_line('Nome:'||v_emp_name||'Salário: '||v_sal);

end;
/

/*#####################################*/

create or replace function f_media_sal_mgr(v_mgr emp.mgr%type) return number
    as 
    v_media emp.sal%type;
begin

    select avg(sal)
    into v_media
    from emp
    where mgr = v_mgr;

    return v_media;
end;
/

